# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files containing secrets
terraform.tfvars
*.auto.tfvars
!*.example

# Lock files (opinion — some teams commit these)
.terraform.lock.hcl

# Terraform dirs
.terraform/
.terraform.d/

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Plan output
*.tfplan
